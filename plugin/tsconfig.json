{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["ES2021"],
    "module": "node16",
    "moduleResolution": "node16",
    "noImplicitAny": true,
    "outDir": "build",
    "rootDir": "src",
    "skipLibCheck": true,
    "types": ["node"],
    "strict": true,
    "target": "ES2021"
  },
  "include": ["src"]
}
